{
	"expo": {
		"name": "mdoc-data-transfer-example",
		"slug": "mdoc-data-transfer-example",
		"version": "1.0.0",
		"orientation": "portrait",
		"scheme": "mdoc-data-transfer-example",
		"userInterfaceStyle": "automatic",
		"plugins": [
			[
				"../expo-sdk/app.plugin.js",
				{
					"ios": {
						"buildStatic": ["RNReanimated"]
					}
				}
			],
			[
				"expo-build-properties",
				{
					"android": {
						"minSdkVersion": 26
					},
					"ios": {
						"useFrameworks": "dynamic",
						"deploymentTarget": "16.0"
					}
				}
			]
		],
		"experiments": {
			"typedRoutes": true
		},
		"android": {
			"package": "foundation.openwallet.mdoc.datatransfer.example",
			"permissions": ["android.permission.BLUETOOTH_CONNECT"]
		},
		"ios": {
			"bundleIdentifier": "foundation.openwallet.mdoc.datatransfer.example",
			"appleTeamId": "G9667JTP83"
		},
		"splash": {
			"backgroundColor": "#ffffff"
		}
	}
}
